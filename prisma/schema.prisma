// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id
  name          String?
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  members       Member[]
  invitations   Invitation[]

  // CRM relations
  crmDeals                CrmDeal[]
  crmActivities           CrmActivity[]
  crmFollowUps            CrmFollowUp[]
  crmNotificationSettings CrmNotificationSettings?
}

model Location {
  id              String   @id @default(cuid())
  name            String
  type            LocationType
  address         String
  city            String
  county          String
  postcode        String
  latitude        Decimal  @db.Decimal(10, 8)
  longitude       Decimal  @db.Decimal(11, 8)
  phone           String?
  website         String?
  openingHours    Json?
  parkingSpaces   Int?
  totalFloorArea  Int?     // in square feet
  numberOfStores  Int?
  numberOfFloors  Int?
  anchorTenants   Int?
  publicTransit   String?
  owner           String?
  regionalManager String?
  management      String?
  managementContact String?
  managementEmail   String?
  managementPhone   String?
  openedYear      Int?
  heroImage       String?  // path to hero background image
  isManaged       Boolean  @default(false)
  
  // Standardized Address Fields
  street          String?
  town            String?
  district        String?  // Administrative district (e.g. Warwick)
  region          String?  // NUTS1 Region (e.g. West Midlands)
  country         String?  // England, Wales, Scotland, NI
  
  // Enhanced details
  footfall        Int?     // annual footfall
  retailers       Int?     // number of retailers
  carParkPrice    Decimal? @db.Decimal(5, 2) // 0-2 hours parking price
  retailSpace     Int?     // retail space in sqft
  evCharging      Boolean? @default(false)
  evChargingSpaces Int?

  // CSV KPIs (optional, sourced from canonical CSV)
  healthIndex                    Decimal? @db.Decimal(5, 2)
  largestCategory                String?
  largestCategoryPercent         Decimal? @db.Decimal(8, 4)
  vacancy                        Decimal? @db.Decimal(8, 4)
  vacancyGrowth                  Decimal? @db.Decimal(8, 4)
  persistentVacancy              Decimal? @db.Decimal(8, 4)
  vacantUnits                    Int?
  vacantUnitGrowth               Int?
  averageTenancyLengthYears      Decimal? @db.Decimal(8, 2)
  percentMultiple                Decimal? @db.Decimal(8, 4)
  percentIndependent             Decimal? @db.Decimal(8, 4)
  qualityOfferMass               Decimal? @db.Decimal(8, 4)
  qualityOfferPremium            Decimal? @db.Decimal(8, 4)
  qualityOfferValue              Decimal? @db.Decimal(8, 4)
  vacantFloorspace               Int?
  vacantFloorspaceGrowth         Decimal? @db.Decimal(8, 4)
  floorspaceVacancy              Decimal? @db.Decimal(8, 4)
  floorspaceVacancyGrowth        Decimal? @db.Decimal(8, 4)
  floorspaceVacancyLeisure       Decimal? @db.Decimal(8, 4)
  floorspaceVacancyLeisureGrowth Decimal? @db.Decimal(8, 4)
  floorspaceVacancyRetail        Decimal? @db.Decimal(8, 4)
  floorspaceVacancyRetailGrowth  Decimal? @db.Decimal(8, 4)
  floorspacePersistentVacancy    Decimal? @db.Decimal(8, 4)
  
  // Social media links
  instagram       String?
  facebook        String?
  youtube         String?
  tiktok          String?
  twitter         String?
  
  // Online reviews
  googleRating    Decimal? @db.Decimal(2, 1)
  googleReviews   Int?
  googleVotes     Int?
  facebookRating  Decimal? @db.Decimal(2, 1)
  facebookReviews Int?
  facebookVotes   Int?
  
  // SEO data
  seoKeywords     Json?    // array of keyword objects
  topPages        Json?    // array of page objects
  
  // Demographics
  population      Int?
  medianAge       Int?
  familiesPercent Decimal? @db.Decimal(4, 1)
  seniorsPercent  Decimal? @db.Decimal(4, 1)
  avgHouseholdIncome Decimal? @db.Decimal(8, 2)
  incomeVsNational Decimal? @db.Decimal(6, 2)
  homeownership   Decimal? @db.Decimal(4, 1)
  homeownershipVsNational Decimal? @db.Decimal(4, 1)
  carOwnership    Decimal? @db.Decimal(4, 1)
  carOwnershipVsNational Decimal? @db.Decimal(4, 1)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  tenants          Tenant[]
  spaces           Space[]
  crmDealLocations CrmDealLocation[]

  @@map("locations")
}

enum SpaceType {
  GENERAL
  CHARITY
  PREMIUM
  PROMOTIONAL
}

enum BookingStatus {
  CONFIRMED
  UNCONFIRMED
  CANCELLED
}

enum OperatorType {
  GENERAL
  CHARITY
  FOOD_AND_BEVERAGE
  RETAIL
  SERVICES
  PROMOTIONAL
}

enum LicenseCategory {
  PUBLIC_LIABILITY_INSURANCE
  FOOD_HYGIENE
  GENERAL_LICENSE
  STREET_TRADING
  ALCOHOL_LICENSE
  FIRE_SAFETY
  OTHER
}

enum ComplianceStatus {
  NOT_CHECKED
  PASSED
  FAILED
  EXPIRED
}

model Operator {
  id                  String            @id @default(cuid())
  companyName         String
  tradingName         String?
  contactName         String?
  contactEmail        String?
  contactPhone        String?
  address             String?
  website             String?

  types               OperatorType[]

  companiesHouseCheck ComplianceStatus  @default(NOT_CHECKED)
  companiesHouseDate  DateTime?
  companiesHouseRef   String?
  accountsNextDue     DateTime?
  confirmationNextDue DateTime?
  creditCheck         ComplianceStatus  @default(NOT_CHECKED)
  creditCheckDate     DateTime?

  notes               String?
  isActive            Boolean           @default(true)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  licenses            OperatorLicense[]
  bookings            SpaceBooking[]

  @@map("operators")
}

model OperatorLicense {
  id           String          @id @default(cuid())
  operatorId   String
  type         LicenseCategory
  reference    String?
  startDate    DateTime
  endDate      DateTime
  isVerified   Boolean         @default(false)
  coverValue   Decimal?        @db.Decimal(12, 2)
  documentUrl  String?
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  operator     Operator        @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([operatorId])
  @@index([endDate])
  @@map("operator_licenses")
}

model Space {
  id               String    @id @default(cuid())
  locationId       String
  name             String
  type             SpaceType @default(GENERAL)
  width            Decimal?  @db.Decimal(5, 2)
  length           Decimal?  @db.Decimal(5, 2)
  hasPower         Boolean   @default(false)
  defaultDailyRate Decimal?  @db.Decimal(8, 2)
  sortOrder        Int       @default(0)
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  location         Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  bookings         SpaceBooking[]

  @@unique([locationId, name])
  @@map("spaces")
}

model SpaceBooking {
  id            String        @id @default(cuid())
  spaceId       String
  operatorId    String?
  reference     String        @unique
  startDate     DateTime
  endDate       DateTime
  status        BookingStatus @default(UNCONFIRMED)

  companyName   String?
  brand         String?
  setupDetail   String?
  description   String?

  dailyRate     Decimal?      @db.Decimal(8, 2)
  totalValue    Decimal?      @db.Decimal(10, 2)

  notes         String?

  // PAT Testing
  patCertNumber String?
  patExpiryDate DateTime?
  equipmentList String?

  createdById   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  space         Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  operator      Operator?     @relation(fields: [operatorId], references: [id])

  @@index([spaceId, startDate, endDate])
  @@index([operatorId])
  @@map("space_bookings")
}

model Tenant {
  id             String   @id @default(cuid())
  locationId     String
  name           String
  category       String
  subcategory    String?
  unitNumber     String?
  floor          Int?
  isAnchorTenant Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  location       Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  // Normalized category reference
  categoryId     String?
  categoryRef    Category? @relation(fields: [categoryId], references: [id])

  @@unique([locationId, name])
  @@map("tenants")
}

model Category {
  id               String     @id @default(cuid())
  name             String     @unique
  description      String?
  tier             Int        @default(3) // 1=Sector, 2=Category, 3=Subcategory
  parentCategoryId String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  parentCategory   Category?  @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id])
  subcategories    Category[] @relation("CategoryHierarchy")
  tenants          Tenant[]

  @@map("categories")
}

model EnrichmentSnapshot {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  
  // Overall stats
  totalLocations  Int
  
  // Tier-level counts (locations that meet tier requirements)
  coreComplete    Int
  geoComplete     Int
  operationalComplete Int
  commercialComplete  Int
  digitalComplete     Int
  demographicComplete Int
  
  // Field-level completeness (JSON for flexibility)
  fieldStats      Json     // { fieldName: { filled: 123, empty: 456 }, ... }
  
  @@map("enrichment_snapshots")
}

enum Role {
  USER
  ADMIN
  REGIONAL_MANAGER
}

enum LocationType {
  SHOPPING_CENTRE
  RETAIL_PARK
  OUTLET_CENTRE
  HIGH_STREET
}

model Session {
  id        String   @id
  userId    String
  token     String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime
  updatedAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("accounts")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verifications")
}

model Organization {
  id        String   @id
  name      String
  slug      String?  @unique
  logo      String?
  metadata  String?
  createdAt DateTime
  
  members     Member[]
  invitations Invitation[]

  @@map("organizations")
}

model Member {
  id             String       @id
  organizationId String
  userId         String
  role           String
  createdAt      DateTime
  
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("members")
}

model Invitation {
  id             String       @id
  organizationId String
  email          String
  role           String?
  status         String
  expiresAt      DateTime
  inviterId      String
  
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter        User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@map("invitations")
}

model ContactSubmission {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  enquiryType String
  message     String
  createdAt   DateTime @default(now())

  @@map("contact_submissions")
}

// ─── CRM Models ─────────────────────────────────────────

enum DealStage {
  LEAD
  CONTACTED
  MEETING_SCHEDULED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum CrmActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  VISIT
  STAGE_CHANGE
  OTHER
}

model CrmOrganisation {
  id        String   @id @default(cuid())
  name      String
  website   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deals    CrmDeal[]
  contacts CrmContact[]

  @@map("crm_organisations")
}

model CrmDeal {
  id             String    @id @default(cuid())
  title          String
  stage          DealStage @default(LEAD)
  value          Int?
  organisationId String?
  ownerId        String

  notes          String?
  stageChangedAt DateTime  @default(now())
  closedAt       DateTime?
  lostReason     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organisation CrmOrganisation? @relation(fields: [organisationId], references: [id])
  owner        User             @relation(fields: [ownerId], references: [id])
  locations    CrmDealLocation[]
  contacts     CrmDealContact[]
  activities   CrmActivity[]
  followUps    CrmFollowUp[]

  @@index([ownerId])
  @@index([stage])
  @@index([organisationId])
  @@map("crm_deals")
}

model CrmDealLocation {
  id           String @id @default(cuid())
  dealId       String
  locationId   String?
  locationName String
  locationCity String?

  deal     CrmDeal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  location Location? @relation(fields: [locationId], references: [id])

  @@unique([dealId, locationId])
  @@index([locationId])
  @@map("crm_deal_locations")
}

model CrmContact {
  id             String  @id @default(cuid())
  name           String
  email          String?
  phone          String?
  linkedin       String?
  jobTitle       String?
  organisationId String?
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organisation CrmOrganisation? @relation(fields: [organisationId], references: [id])
  deals        CrmDealContact[]

  @@map("crm_contacts")
}

model CrmDealContact {
  id        String @id @default(cuid())
  dealId    String
  contactId String

  deal    CrmDeal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contact CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([dealId, contactId])
  @@map("crm_deal_contacts")
}

model CrmActivity {
  id        String          @id @default(cuid())
  dealId    String
  userId    String
  type      CrmActivityType
  content   String
  createdAt DateTime        @default(now())

  deal CrmDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user User    @relation(fields: [userId], references: [id])

  @@index([dealId])
  @@map("crm_activities")
}

model CrmFollowUp {
  id          String    @id @default(cuid())
  dealId      String
  userId      String
  dueDate     DateTime
  description String
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  deal CrmDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user User    @relation(fields: [userId], references: [id])

  @@index([userId, dueDate])
  @@index([dealId])
  @@map("crm_follow_ups")
}

model CrmNotificationSettings {
  id            String  @id @default(cuid())
  userId        String  @unique
  digestEnabled Boolean @default(false)
  digestTime    String  @default("07:00")

  user User @relation(fields: [userId], references: [id])

  @@map("crm_notification_settings")
}
